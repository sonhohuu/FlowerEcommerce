@page
@model FlowerEcommerce.View.Pages.Introduction.IndexModel
@{
    ViewData["Title"] = "Giới thiệu";
}

@section Styles {
    <style>
        .breadcrumb {
            padding: 12px 40px;
            font-size: 14px;
            color: #555;
            background: #f5f5f5;
            border-bottom: 1px solid #e0e0e0;
        }

            .breadcrumb a {
                color: #555;
                text-decoration: none;
            }

                .breadcrumb a:hover {
                    text-decoration: underline;
                }

            .breadcrumb .active {
                color: #1a8cff;
                font-weight: 600;
            }

        .about-wrapper {
            max-width: 900px;
            margin: 48px auto;
            padding: 0 24px;
        }

            .about-wrapper h1 {
                font-family: 'Oswald', sans-serif;
                font-size: 40px;
                font-weight: 700;
                color: #111;
                margin-bottom: 32px;
            }

        .about-section {
            margin-bottom: 32px;
        }

            .about-section h2 {
                font-family: 'Source Sans 3', sans-serif;
                font-size: 15px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                color: #111;
                margin-bottom: 12px;
            }

            .about-section p {
                font-family: 'Source Sans 3', sans-serif;
                font-size: 15px;
                line-height: 1.8;
                color: #444;
                margin: 0;
            }

                .about-section p + p {
                    margin-top: 10px;
                }

        .about-divider {
            border: none;
            border-top: 1px solid #e8e8e8;
            margin: 28px 0;
        }

        /* Highlight box */
        .highlight-box {
            background: #f0f7ff;
            border-left: 4px solid #1a8cff;
            border-radius: 4px;
            padding: 18px 22px;
            margin-bottom: 32px;
        }

            .highlight-box p {
                font-family: 'Source Sans 3', sans-serif;
                font-size: 15px;
                font-weight: 600;
                color: #1a5fa8;
                margin: 0;
                line-height: 1.6;
                text-transform: uppercase;
                letter-spacing: 0.3px;
            }

        /* Feature grid */
        .feature-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 40px;
        }

        .feature-card {
            text-align: center;
            padding: 28px 20px;
            border: 1px solid #ebebeb;
            border-radius: 8px;
            transition: box-shadow 0.2s;
        }

            .feature-card:hover {
                box-shadow: 0 4px 18px rgba(0,0,0,0.08);
            }

            .feature-card .icon {
                font-size: 32px;
                margin-bottom: 12px;
            }

            .feature-card h3 {
                font-family: 'Oswald', sans-serif;
                font-size: 15px;
                font-weight: 600;
                color: #111;
                margin: 0 0 8px;
                text-transform: uppercase;
            }

            .feature-card p {
                font-size: 13px;
                color: #666;
                line-height: 1.6;
                margin: 0;
            }
    </style>
}

<!-- Breadcrumb -->
<div class="breadcrumb">
    <a href="/">Trang chủ</a> &gt; <span class="active">Giới thiệu</span>
</div>

<div class="about-wrapper">
    <h1>Giới thiệu</h1>

    <div class="highlight-box">
        <p>CanCau Shop — Cửa hàng cầu vô địch hàng đầu Việt Nam</p>
    </div>

    <div class="about-section">
        <h2>CanCau Shop — Mua sắm thể thao trực tuyến hàng đầu Việt Nam</h2>
        <p>
            CanCau Shop sẽ mang lại cho khách hàng những trải nghiệm mua sắm thể thao trực tuyến thú vị từ các thương hiệu
            quốc tế và trong nước. Chúng tôi cam kết chất lượng phục vụ hàng đầu cùng với những bộ sưu tập đa dạng từ
            vợt cầu lông, giày thể thao đến phụ kiện tập luyện cho cả nam và nữ với những xu hướng mới nhất.
        </p>
        <p>
            Bạn có thể tìm thấy những sản phẩm mình muốn từ những bộ đồ thoải mái hay tự tin trong những bộ trang phục
            thi đấu chuyên nghiệp. Những trải nghiệm mới chỉ có ở cửa hàng thể thao trực tuyến CanCau Shop.
        </p>
    </div>

    <hr class="about-divider" />

    <div class="about-section">
        <h2>CanCau Shop — Món quà tặng người thân thật ý nghĩa!</h2>
        <p>
            CanCau Shop sẽ gợi ý cho bạn những món quà thật ý nghĩa để tặng người thân, bạn bè yêu thể thao.
            Chúng tôi sẽ làm bạn hài lòng với sự lựa chọn của mình bằng giá tốt nhất và chất lượng dịch vụ hoàn hảo.
        </p>
    </div>

    <hr class="about-divider" />

    <div class="about-section">
        <h2>Mua sắm ở CanCau Shop — Phù hợp với túi tiền từ vận động viên, học sinh đến người đam mê thể thao</h2>
        <p>
            CanCau Shop luôn cập nhật những xu hướng thể thao phong cách nhất từ những hãng cao cấp như Yonex, Victor,
            Li-Ning cho tới những thương hiệu tầm trung đa dạng lựa chọn. Đặc biệt, CanCau Shop còn có nhiều đợt khuyến mãi,
            giảm giá đặc biệt với giá tốt nhất. Sản phẩm chất lượng cao, phù hợp túi tiền — chỉ có ở CanCau Shop!
        </p>
    </div>

    <hr class="about-divider" />

    <div class="about-section">
        <h2>Phong cách mua sắm hiện đại — Thuận tiện, thanh toán an toàn, dễ dàng</h2>
        <p>
            Với giao diện thân thiện, quy trình đặt hàng đơn giản và nhiều phương thức thanh toán an toàn, CanCau Shop
            cam kết mang đến trải nghiệm mua sắm trực tuyến tốt nhất cho mọi khách hàng trên toàn quốc.
        </p>
    </div>

    <!-- Feature Grid -->
    <div class="feature-grid">
        <div class="feature-card">
            <div class="icon">🚚</div>
            <h3>Giao hàng nhanh</h3>
            <p>Giao hàng toàn quốc trong 2–3 ngày làm việc. Miễn phí vận chuyển đơn từ 500.000đ.</p>
        </div>
        <div class="feature-card">
            <div class="icon">🔒</div>
            <h3>Thanh toán an toàn</h3>
            <p>Hỗ trợ COD, chuyển khoản, MoMo, ZaloPay và thẻ tín dụng.</p>
        </div>
        <div class="feature-card">
            <div class="icon">↩️</div>
            <h3>Đổi trả dễ dàng</h3>
            <p>Chính sách đổi trả trong 7 ngày nếu sản phẩm lỗi hoặc không đúng mô tả.</p>
        </div>
    </div>
</div>
