@page
@model FlowerEcommerce.View.Pages.RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = "_AuthLayout";
}

<div class="glass-card">
    <h1 class="card-title">Create Account</h1>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="error-summary"></div>

        <div class="form-row">
            <div class="form-group">
                <label class="field-label" asp-for="Input.FirstName">First Name</label>
                <input asp-for="Input.FirstName" class="field-input" placeholder="First name" />
                <span asp-validation-for="Input.FirstName" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label class="field-label" asp-for="Input.LastName">Last Name</label>
                <input asp-for="Input.LastName" class="field-input" placeholder="Last name" />
                <span asp-validation-for="Input.LastName" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="field-label" asp-for="Input.Username">Username</label>
            <input asp-for="Input.Username" class="field-input" placeholder="Choose a username" autocomplete="username" />
            <span asp-validation-for="Input.Username" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label class="field-label" asp-for="Input.Email">Email</label>
            <input asp-for="Input.Email" class="field-input" placeholder="your@email.com" autocomplete="email" />
            <span asp-validation-for="Input.Email" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label class="field-label" asp-for="Input.Password">Password</label>
            <input asp-for="Input.Password" class="field-input" placeholder="Create a password" autocomplete="new-password" />
            <span asp-validation-for="Input.Password" class="field-validation-error"></span>
        </div>

        <button type="submit" class="submit-btn">Create Account</button>
    </form>

    <p class="switch-text">
        Already have an account? <a asp-page="/Login" class="switch-link">Login</a>
    </p>
</div>
