@page
@model FlowerEcommerce.View.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Tất cả sản phẩm";
    var currentCategory = Request.Query["category"].ToString();
    var currentSort = Request.Query["sort"].ToString();
    var currentSearch = Request.Query["search"].ToString();

    // Resolve the display name for the current category slug
    var currentCategoryName = Model.Categories
        .FirstOrDefault(c => c.Slug == currentCategory)?.Name
        ?? "Tất cả sản phẩm";
}

@section Styles {
    <style>
        /* ── Breadcrumb ── */
        .breadcrumb {
            padding: 12px 40px;
            font-size: 14px;
            color: #555;
            background: #f5f5f5;
            border-bottom: 1px solid #e0e0e0;
        }

            .breadcrumb a {
                color: #555;
                text-decoration: none;
            }

                .breadcrumb a:hover {
                    text-decoration: underline;
                }

            .breadcrumb .active {
                color: #1a8cff;
                font-weight: 600;
            }

        /* ── Layout ── */
        .shop-wrapper {
            display: flex;
            max-width: 1280px;
            margin: 32px auto;
            padding: 0 24px;
            gap: 40px;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 220px;
            flex-shrink: 0;
        }

            .sidebar h3 {
                font-family: 'Oswald', sans-serif;
                font-size: 15px;
                font-weight: 700;
                letter-spacing: 0.5px;
                text-transform: uppercase;
                color: #111;
                margin-bottom: 18px;
                border-bottom: 2px solid #111;
                padding-bottom: 10px;
            }

            .sidebar ul {
                list-style: none;
                padding: 0;
                margin: 0;
            }

                .sidebar ul li {
                    border-bottom: 1px solid #ebebeb;
                }

                    .sidebar ul li a {
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                        padding: 12px 4px;
                        font-size: 14px;
                        color: #333;
                        text-decoration: none;
                        transition: color 0.2s;
                    }

                        .sidebar ul li a:hover,
                        .sidebar ul li a.active-cat {
                            color: #1a8cff;
                            font-weight: 600;
                        }

                        .sidebar ul li a .arrow {
                            font-size: 11px;
                            color: #aaa;
                        }

        /* ── Product Grid ── */
        .product-section {
            flex: 1;
        }

        .product-section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

            .product-section-header h2 {
                font-family: 'Oswald', sans-serif;
                font-size: 20px;
                font-weight: 700;
                letter-spacing: 0.5px;
                text-transform: uppercase;
                color: #111;
                margin: 0;
            }

        .sort-select {
            padding: 8px 14px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 14px;
            color: #333;
            background: #fff;
            cursor: pointer;
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }

        /* ── Product Card ── */
        .product-card {
            background: #fff;
            border: 1px solid #ebebeb;
            border-radius: 6px;
            overflow: hidden;
            transition: box-shadow 0.2s, transform 0.2s;
            cursor: pointer;
        }

            .product-card:hover {
                box-shadow: 0 6px 24px rgba(0,0,0,0.10);
                transform: translateY(-3px);
            }

        .product-card-img {
            position: relative;
            aspect-ratio: 1 / 1;
            overflow: hidden;
            background: #f9f9f9;
        }

            .product-card-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.3s;
            }

        .product-card:hover .product-card-img img {
            transform: scale(1.05);
        }

        .product-card-link {
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .badge {
            position: absolute;
            top: 10px;
            left: 10px;
            background: #e63b3b;
            color: #fff;
            font-size: 12px;
            font-weight: 700;
            padding: 3px 8px;
            border-radius: 3px;
        }

        .badge-outofstock {
            position: absolute;
            top: 10px;
            right: 10px;
            background: #888;
            color: #fff;
            font-size: 11px;
            font-weight: 600;
            padding: 3px 8px;
            border-radius: 3px;
        }

        .product-card-body {
            padding: 14px 16px;
        }

            .product-card-body h4 {
                font-size: 14px;
                font-weight: 600;
                color: #222;
                margin: 0 0 8px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

        .price-row {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .price-new {
            font-size: 15px;
            font-weight: 700;
            color: #e63b3b;
        }

        .price-old {
            font-size: 13px;
            color: #aaa;
            text-decoration: line-through;
        }

        .price-contact {
            font-size: 14px;
            color: #e63b3b;
            font-weight: 600;
        }

        .btn-add-cart {
            margin-top: 12px;
            width: 100%;
            padding: 9px;
            background: #111;
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
        }

            .btn-add-cart:hover {
                background: #1a8cff;
            }

            .btn-add-cart:disabled {
                background: #aaa;
                cursor: not-allowed;
            }

        /* ── Empty state ── */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #888;
            font-size: 15px;
            grid-column: 1 / -1;
        }

        /* ── Pagination ── */
        .pagination {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 40px;
        }

            .pagination a {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 36px;
                height: 36px;
                border: 1px solid #ddd;
                border-radius: 4px;
                font-size: 14px;
                color: #333;
                text-decoration: none;
                transition: all 0.2s;
            }

                .pagination a.active, .pagination a:hover {
                    background: #111;
                    color: #fff;
                    border-color: #111;
                }

        /* ── Skeleton ── */
        .skeleton-card {
            background: #fff;
            border: 1px solid #ebebeb;
            border-radius: 6px;
            overflow: hidden;
        }

        .skeleton-img {
            aspect-ratio: 1 / 1;
            background: linear-gradient(90deg, #f0f0f0 25%, #e4e4e4 50%, #f0f0f0 75%);
            background-size: 200% 100%;
            animation: shimmer 1.4s infinite;
        }

        .skeleton-body {
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .skeleton-line {
            height: 13px;
            border-radius: 4px;
            background: linear-gradient(90deg, #f0f0f0 25%, #e4e4e4 50%, #f0f0f0 75%);
            background-size: 200% 100%;
            animation: shimmer 1.4s infinite;
        }

            .skeleton-line.w80 {
                width: 80%;
            }

            .skeleton-line.w50 {
                width: 50%;
            }

            .skeleton-line.w100 {
                width: 100%;
            }

            .skeleton-line.btn-line {
                height: 34px;
                margin-top: 4px;
            }

        @@keyframes shimmer {
            from {
                background-position: 200% 0;
            }

            to {
                background-position: -200% 0;
            }
        }
    </style>
}

<!-- Breadcrumb -->
<div class="breadcrumb">
    <a href="/">Trang chủ</a> >
    @if (string.IsNullOrEmpty(currentCategory))
    {
        <span class="active">Tất cả sản phẩm</span>
    }
    else
    {
        <text><a href="/Products">Tất cả sản phẩm</a> > <span class="active">@currentCategoryName</span></text>
    }
</div>

<div class="shop-wrapper">
    <!-- Sidebar — rendered from API data -->
    <aside class="sidebar">
        <h3>Danh mục sản phẩm</h3>
        <ul>
            <!-- "All products" link -->
            <li>
                <a href="?category=" class="@(string.IsNullOrEmpty(currentCategory) ? "active-cat" : "")">
                    Tất cả <span class="arrow">›</span>
                </a>
            </li>

            <!-- Dynamic categories from API -->
            @foreach (var cat in Model.Categories)
            {
                <li>
                    <a href="?category=@cat.Slug"
                       class="@(currentCategory == cat.Slug ? "active-cat" : "")">
                        @cat.Name <span class="arrow">›</span>
                    </a>
                </li>
            }
        </ul>
    </aside>

    <!-- Products -->
