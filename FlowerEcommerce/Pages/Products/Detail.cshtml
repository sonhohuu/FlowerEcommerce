@page "{slug}"
@using FlowerEcommerce.View.Helpers
@model FlowerEcommerce.View.Pages.Products.DetailModel
@{
    ViewData["Title"] = Model.Product?.Name ?? "Chi tiết sản phẩm";
    var p = Model.Product;

    // Reviews
    var reviews = Model.Reviews;
    var totalCount = reviews.TotalCount;
    double avgScore = 0;
    if (totalCount > 0 && reviews.Items.Any())
    {
        avgScore = reviews.Items.Sum(r => r.Score) / (double)totalCount;
    }
}

@section Styles {
    <style>
        .breadcrumb {
            padding: 12px 40px;
            font-size: 14px;
            color: #555;
            background: #f5f5f5;
            border-bottom: 1px solid #e0e0e0;
        }

            .breadcrumb a {
                color: #555;
                text-decoration: none;
            }

                .breadcrumb a:hover {
                    text-decoration: underline;
                }

            .breadcrumb .active {
                color: #e55a00;
                font-weight: 600;
            }

        /* ── Detail Wrapper ── */
        .detail-wrapper {
            max-width: 1200px;
            margin: 36px auto;
            padding: 0 24px;
            display: grid;
            grid-template-columns: 500px 1fr;
            gap: 56px;
        }

        /* ── Gallery ── */
        .gallery {
            position: relative;
        }

        .gallery-main {
            width: 100%;
            aspect-ratio: 1 / 1;
            border: 1px solid #e5e5e5;
            border-radius: 8px;
            overflow: hidden;
            background: #f9f9f9;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

            .gallery-main img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                transition: opacity 0.25s;
            }

        .gallery-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(0,0,0,0.35);
            color: #fff;
            border: none;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            font-size: 16px;
            cursor: pointer;
            z-index: 2;
            transition: background 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .gallery-nav:hover {
                background: rgba(0,0,0,0.6);
            }

            .gallery-nav.prev {
                left: 10px;
            }

            .gallery-nav.next {
                right: 10px;
            }

        .gallery-thumbs {
            display: flex;
            gap: 10px;
            margin-top: 14px;
            flex-wrap: wrap;
        }

            .gallery-thumbs img {
                width: 72px;
                height: 72px;
                object-fit: cover;
                border: 2px solid #e5e5e5;
                border-radius: 6px;
                cursor: pointer;
                transition: border-color 0.2s;
            }

                .gallery-thumbs img.active,
                .gallery-thumbs img:hover {
                    border-color: #e55a00;
                }

        /* ── Product Info ── */
        .product-info h1 {
            font-family: 'Oswald', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: #111;
            text-transform: uppercase;
            line-height: 1.4;
            margin: 0 0 16px;
        }

        .product-info hr {
            border: none;
            border-top: 1px solid #e5e5e5;
            margin: 18px 0;
        }

        /* Price */
        .price-block {
            margin-bottom: 16px;
        }

        .price-label {
            font-size: 13px;
            color: #888;
            margin-bottom: 4px;
        }

        .price-main {
            font-size: 26px;
            font-weight: 700;
            color: #e55a00;
        }

            .price-main.out-of-stock {
                color: #e55a00;
            }

        .price-original {
            font-size: 14px;
            color: #aaa;
            text-decoration: line-through;
            margin-left: 8px;
        }

        /* Meta */
        .meta-row {
            font-size: 14px;
            color: #444;
            margin-bottom: 8px;
            display: flex;
            gap: 6px;
        }

            .meta-row .label {
                font-weight: 600;
                color: #222;
                min-width: 110px;
                flex-shrink: 0;
            }

            .meta-row .val-link {
                color: #1a8cff;
            }

        /* Specs table */
        .specs-block {
            background: #f8f8f8;
            border-radius: 6px;
            padding: 16px 20px;
            margin: 16px 0;
            font-size: 13.5px;
            color: #444;
            line-height: 2;
        }

            .specs-block b {
                color: #222;
            }

        /* ── Size Options ── */
        .size-options {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .size-option-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            padding: 10px 16px;
            border: 2px solid #ddd;
            border-radius: 6px;
            background: #fafafa;
            cursor: pointer;
            transition: border-color 0.2s, background 0.2s, transform 0.15s;
            min-width: 90px;
            text-align: center;
        }

            .size-option-btn:hover {
                border-color: #e55a00;
                background: #fff8f5;
                transform: translateY(-2px);
            }

            .size-option-btn.selected {
                border-color: #e55a00;
                background: #fff3ed;
                box-shadow: 0 0 0 3px rgba(229,90,0,0.12);
            }

        .size-label {
            font-size: 13px;
            font-weight: 700;
            color: #222;
        }

        .size-option-btn.selected .size-label {
            color: #e55a00;
        }

        .size-price {
            font-size: 12px;
            font-weight: 600;
            color: #e55a00;
        }

        /* Address */
        .contact-row {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #555;
            margin-bottom: 6px;
        }

            .contact-row .icon {
                font-size: 15px;
            }

        /* Qty + Buttons */
        .action-row {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .qty-label {
            font-size: 14px;
            font-weight: 600;
            color: #222;
        }

        .qty-control {
            display: flex;
            align-items: center;
            border: 1px solid #ddd;
            border-radius: 4px;
            overflow: hidden;
        }

            .qty-control button {
                width: 34px;
                height: 40px;
                background: #f3f3f3;
                border: none;
                font-size: 18px;
                cursor: pointer;
                color: #444;
                transition: background 0.15s;
            }

                .qty-control button:hover {
                    background: #e5e5e5;
                }

            .qty-control input {
                width: 46px;
                height: 40px;
                border: none;
                border-left: 1px solid #ddd;
                border-right: 1px solid #ddd;
                text-align: center;
                font-size: 14px;
                font-weight: 600;
                color: #222;
            }

        .btn-buy {
            padding: 11px 26px;
            background: #e55a00;
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            transition: background 0.2s;
        }

            .btn-buy:hover {
                background: #c44e00;
            }

        .btn-cart {
            padding: 11px 26px;
            background: #28a745;
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            transition: background 0.2s;
        }

            .btn-cart:hover {
                background: #218838;
            }

        /* ── Related Products ── */
        .related-section {
            max-width: 1200px;
            margin: 48px auto 56px;
            padding: 0 24px;
        }

            .related-section h2 {
                font-family: 'Oswald', sans-serif;
                font-size: 18px;
                font-weight: 700;
                text-transform: uppercase;
                color: #111;
                margin-bottom: 24px;
                padding-bottom: 10px;
                border-bottom: 3px solid #e55a00;
                display: inline-block;
            }

        .related-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 18px;
        }

        .related-card {
            border: 1px solid #ebebeb;
            border-radius: 6px;
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            transition: box-shadow 0.2s, transform 0.2s;
        }

            .related-card:hover {
                box-shadow: 0 4px 18px rgba(0,0,0,0.09);
                transform: translateY(-3px);
            }

            .related-card img {
                width: 100%;
                aspect-ratio: 1 / 1;
                object-fit: cover;
                background: #f5f5f5;
            }

        .related-card-body {
            padding: 10px 12px;
        }

            .related-card-body p {
                font-size: 13px;
                color: #333;
                margin: 0 0 6px;
                line-height: 1.4;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

            .related-card-body .price {
                font-size: 14px;
                font-weight: 700;
                color: #e55a00;
            }

        /* ── Product Reviews ── */
        .reviews-section {
            max-width: 1200px;
            margin: 0 auto 60px;
            padding: 0 24px;
        }

            .reviews-section h2 {
                font-family: 'Oswald', sans-serif;
                font-size: 18px;
                font-weight: 700;
                text-transform: uppercase;
                color: #111;
                margin-bottom: 24px;
                padding-bottom: 10px;
                border-bottom: 3px solid #e55a00;
                display: inline-block;
            }

        .reviews-summary {
            display: flex;
            align-items: center;
            gap: 32px;
            background: #fafafa;
            border: 1px solid #ebebeb;
            border-radius: 10px;
            padding: 24px 32px;
            margin-bottom: 28px;
        }

        .summary-score {
            text-align: center;
            min-width: 90px;
        }

            .summary-score .big-num {
                font-size: 52px;
                font-weight: 800;
                color: #e55a00;
                line-height: 1;
            }

            .summary-score .stars-display {
                color: #f5a623;
                font-size: 18px;
                margin: 4px 0;
                letter-spacing: 2px;
            }

            .summary-score .total-reviews {
                font-size: 12px;
                color: #888;
            }

        .summary-bars {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .bar-row {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            color: #555;
        }

            .bar-row .bar-label {
                min-width: 36px;
                text-align: right;
                color: #f5a623;
                font-size: 12px;
            }

        .bar-track {
            flex: 1;
            height: 8px;
            background: #e8e8e8;
            border-radius: 4px;
            overflow: hidden;
        }

        .bar-fill {
            height: 100%;
            background: linear-gradient(90deg, #f5a623, #e55a00);
            border-radius: 4px;
            transition: width 0.6s ease;
        }

        .bar-count {
            min-width: 20px;
            font-size: 12px;
            color: #999;
        }

        .btn-load-more {
            padding: 10px 28px;
            border: 2px solid #e55a00;
            background: transparent;
            color: #e55a00;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
        }

            .btn-load-more:hover {
                background: #e55a00;
                color: #fff;
            }

            .btn-load-more:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }

        /* Review list */
        .reviews-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 28px;
        }

        .review-card {
            border: 1px solid #ebebeb;
            border-radius: 8px;
            padding: 18px 20px;
            background: #fff;
            transition: box-shadow 0.2s;
        }

            .review-card:hover {
                box-shadow: 0 3px 14px rgba(0,0,0,0.07);
            }

        .review-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 10px;
        }

        .review-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #e55a00, #f5a623);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .review-meta {
            flex: 1;
        }

            .review-meta .reviewer-name {
                font-size: 14px;
                font-weight: 700;
                color: #111;
            }

        .review-stars {
            color: #f5a623;
            font-size: 14px;
            letter-spacing: 1px;
        }

        .review-comment {
            font-size: 14px;
            color: #444;
            line-height: 1.7;
            margin: 0;
        }

        /* Write review form */
        .write-review {
            background: #f8f8f8;
            border: 1px solid #e5e5e5;
            border-radius: 10px;
            padding: 24px 28px;
        }

            .write-review h3 {
                font-size: 15px;
                font-weight: 700;
                color: #111;
                margin: 0 0 18px;
            }

        .form-row {
            margin-bottom: 14px;
        }

            .form-row label {
                display: block;
                font-size: 13px;
                font-weight: 600;
                color: #333;
                margin-bottom: 6px;
            }

            .form-row input[type="text"],
            .form-row textarea {
                width: 100%;
                padding: 10px 14px;
                border: 1px solid #ddd;
                border-radius: 6px;
                font-size: 14px;
                color: #222;
                background: #fff;
                box-sizing: border-box;
                transition: border-color 0.2s;
                resize: vertical;
            }

                .form-row input[type="text"]:focus,
                .form-row textarea:focus {
                    outline: none;
                    border-color: #e55a00;
                }

        /* Star rating input */
        .star-rating-input {
            display: flex;
            gap: 6px;
            flex-direction: row-reverse;
            justify-content: flex-end;
        }

            .star-rating-input input[type="radio"] {
                display: none;
            }

            .star-rating-input label {
                font-size: 28px;
                color: #ddd;
                cursor: pointer;
                transition: color 0.15s, transform 0.15s;
                margin: 0;
                line-height: 1;
            }

                .star-rating-input label:hover,
                .star-rating-input label:hover ~ label,
                .star-rating-input input:checked ~ label {
                    color: #f5a623;
                    transform: scale(1.15);
                }

        .btn-submit-review {
            padding: 11px 28px;
            background: #e55a00;
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            transition: background 0.2s;
            margin-top: 6px;
        }

            .btn-submit-review:hover {
                background: #c44e00;
            }

        .review-empty {
            text-align: center;
            padding: 32px;
            color: #aaa;
            font-size: 14px;
            font-style: italic;
        }

        @@media (max-width: 900px) {
            .detail-wrapper {
                grid-template-columns: 1fr;
            }

            .related-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 600px) {
            .reviews-summary {
                flex-direction: column;
                gap: 16px;
            }
        }
    </style>
}

<!-- Breadcrumb -->
<div class="breadcrumb">
    <a href="/">Trang chủ</a>
    <span> &gt; </span>
    <a href="/Products">Tất cả sản phẩm</a>
    @if (p?.Category != null)
    {
        <span> &gt; </span>
        <a href="/Products?category=@p.CategorySlug">@p.Category</a>
    }
    <span> &gt; </span>
    <span class="active">@p?.Name</span>
</div>

@if (p == null)
{
    <div style="text-align:center;padding:80px 24px;">
        <h2 style="color:#aaa;">Không tìm thấy sản phẩm</h2>
        <a href="/Products" style="color:#1a8cff;">← Quay lại danh sách sản phẩm</a>
    </div>
}
else
{
    <div class="detail-wrapper">
        <!-- GALLERY -->
        <div class="gallery">
            <div class="gallery-main">
                <button class="gallery-nav prev" onclick="changeImg(-1)">&#8249;</button>
                <img id="main-img" src="@p.Images[0]" alt="@p.Name" />
                <button class="gallery-nav next" onclick="changeImg(1)">&#8250;</button>
            </div>
            <div class="gallery-thumbs">
                @for (int i = 0; i < p.Images.Count; i++)
                {
                    <img src="@p.Images[i]"
                         alt="@p.Name ảnh @(i + 1)"
                         class="@(i == 0 ? "active" : "")"
                         onclick="setImg(@i)" />
                }
            </div>
        </div>

        <!-- INFO -->
        <div class="product-info">
            <h1>@p.Name</h1>
            <hr />

            <!-- Price -->
            <div class="price-block">
                <div class="price-label">Giá bán</div>
                @if (p.IsOutOfStock)
                {
                    <span class="price-main out-of-stock">Hết hàng</span>
                    @if (p.OriginalPrice.HasValue)
                    {
                        <span class="price-original">Giá cũ: @p.OriginalPrice.Value.ToString("N0")đ</span>
                    }
                }
                else if (p.IsContactPrice)
                {
                    <span class="price-main">Liên hệ</span>
                }
                else
                {
                    <span class="price-main">@p.Price.ToString("N0")đ</span>
                    @if (p.OriginalPrice.HasValue)
                    {
                        <span class="price-original">@p.OriginalPrice.Value.ToString("N0")đ</span>
                    }
                }
            </div>

            <!-- Meta -->
            <div class="meta-row">
                <span class="label">Mã sản phẩm:</span>
                <span><b>@p.Sku</b></span>
            </div>
            <div class="meta-row">
                <span class="label">Tình trạng:</span>
                <span class="val-link">@(p.IsOutOfStock ? "Hết hàng" : "Còn hàng")</span>
            </div>

            <hr />

            <!-- Description -->
            @if (!string.IsNullOrWhiteSpace(p.Description))
            {
                <div style="font-size:14px;font-weight:700;color:#111;margin-bottom:10px;">Mô tả:</div>
                <div class="specs-block">@Html.SafeHtml(p.Description)</div>
            }

            <!-- Size price table -->
            @if (p.SizePrices.Any())
            {
                <div style="margin: 16px 0;">
                    <div style="font-size:13px;font-weight:700;color:#222;margin-bottom:10px;">
                        Chọn size / loại:
                    </div>
                    <div class="size-options" id="size-options">
                        @foreach (var sp in p.SizePrices)
                        {
                            <button class="size-option-btn"
                                    data-label="@sp.Label"
                                    data-price="@sp.Price"
                                    onclick="selectSize(this)">
                                <span class="size-label">@sp.Label</span>
                                <span class="size-price">@sp.Price.ToString("N0")đ</span>
                            </button>
                        }
                    </div>
                    <div class="size-error" id="size-error" style="display:none;color:#e55a00;font-size:13px;margin-top:6px;">
                        ⚠ Vui lòng chọn size trước khi thêm vào giỏ
                    </div>
                </div>
            }

            <!-- Address -->
            <div class="contact-row">
                <span class="icon">🏪</span>
                <span>Địa chỉ: 1/15 Đường TA05 - Thới An - Quận 12 - TP.HCM</span>
            </div>
            <div class="contact-row">
                <span class="icon">📞</span>
                <span>Điện thoại: <b>0987 926 535</b></span>
            </div>

            <!-- Actions -->
            <div class="action-row">
                <span class="qty-label">Số lượng</span>
                <div class="qty-control">
                    <button onclick="changeDetailQty(-1)">−</button>
                    <input type="number" id="qty-input" value="1" min="1" max="99" />
                    <button onclick="changeDetailQty(1)">+</button>
                </div>
                <button class="btn-buy" onclick="buyNow()">Mua ngay</button>
                <button class="btn-cart" onclick="addToCartDetail()">
                    Thêm vào giỏ hàng
                </button>
            </div>
        </div>
    </div>

    <!-- RELATED PRODUCTS -->
    @if (Model.RelatedProducts.Any())
    {
        <div class="related-section">
            <h2>Sản phẩm khác cùng loại</h2>
            <div class="related-grid">
                @foreach (var rp in Model.RelatedProducts)
                {
                    <a class="related-card" href="/Products/@rp.Id">
                        <img src="@rp.ImageUrl" alt="@rp.Name" />
                        <div class="related-card-body">
                            <p>@rp.Name</p>
                            <div class="price">
                                @if (rp.IsContactPrice)
                                {
                                    <span>Liên hệ</span>
                                }
                                else
                                {
                                    <span>@rp.Price.ToString("N0")đ</span>
                                }
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>
    }

    <div class="reviews-section">
        <h2>Đánh giá sản phẩm</h2>

        <!-- Summary -->
        <div class="reviews-summary">
            <div class="summary-score">
                <div class="big-num" id="avg-score">@(totalCount > 0 ? avgScore.ToString("F1") : "0.0")</div>
                <div class="stars-display" id="avg-stars">
                    @for (int s = 1; s <= 5; s++)
                    {
                        <span>@(s <= Math.Round(avgScore) ? "★" : "☆")</span>
                    }
                </div>
                <div class="total-reviews">
                    <span id="review-count">@totalCount</span> đánh giá
                </div>
            </div>
            <div class="summary-bars">
                @for (int s = 5; s >= 1; s--)
                {
                    var cnt = reviews.Items.Count(r => r.Score == s);
                    var pct = totalCount > 0 ? cnt * 100 / totalCount : 0;
                    <div class="bar-row">
                        <span class="bar-label">@s ★</span>
                        <div class="bar-track">
                            <div class="bar-fill" id="bar-@s" style="width:@pct%"></div>
                        </div>
                        <span class="bar-count" id="bar-count-@s">@cnt</span>
                    </div>
                }
            </div>
        </div>

        <!-- Review list -->
        <div class="reviews-list" id="reviews-list">
            @if (!reviews.Items.Any())
            {
                <div class="review-empty" id="empty-msg">Chưa có đánh giá nào. Hãy là người đầu tiên!</div>
            }
            else
            {
                @foreach (var r in reviews.Items)
                {
                    var initials = string.Join("", r.UserName?.Split(' ')
                        .Where(w => w.Length > 0).Select(w => w[0])).ToUpper();
                    initials = initials.Length > 2 ? initials[..2] : initials;
                    <div class="review-card">
                        <div class="review-header">
                            <div class="review-avatar">@initials</div>
                            <div class="review-meta">
                                <div class="reviewer-name">@r.UserName</div>
                            </div>
                            <div class="review-stars">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <span>@(s <= r.Score ? "★" : "☆")</span>
                                }
                            </div>
                        </div>
                        <p class="review-comment">@r.Comment</p>
                    </div>
                }
            }
        </div>

        <!-- Load more -->
        @if (reviews.TotalPages > 1)
        {
            <div style="text-align:center;margin:12px 0 24px;">
                <button class="btn-load-more" id="btn-load-more"
                        onclick="loadMoreReviews()"
                        data-page="2"
                        data-total="@reviews.TotalPages">
                    Xem thêm đánh giá
                </button>
            </div>
        }

        <!-- Write review form -->
        <div class="write-review">
            <h3>✍️ Viết đánh giá của bạn</h3>
            <div class="form-row">
                <label>Đánh giá *</label>
                <div class="star-rating-input">
                    @for (int s = 5; s >= 1; s--)
                    {
                        <input type="radio" name="rv-score" id="rv-star-@s" value="@s" />
                        <label for="rv-star-@s" title="@s sao">★</label>
                    }
                </div>
            </div>
            <div class="form-row">
                <label>Nhận xét *</label>
                <textarea id="rv-comment" rows="4"
                          placeholder="Chia sẻ cảm nhận của bạn về sản phẩm..."></textarea>
            </div>
            @Html.AntiForgeryToken()
            <button class="btn-submit-review" id="btn-submit-rv" onclick="submitReview()">
                Gửi đánh giá
            </button>
        </div>
    </div>

} @* ← đóng else p == null *@

@section Scripts {
    <script>
        const images      = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(p?.Images ?? new List<string>()));
        const productId   = @p.Id;
        const productName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(p?.Name ?? ""));
        const productImg  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(p?.Images?.FirstOrDefault() ?? ""));
        const hasSizes    = @Html.Raw(p.SizePrices.Any() ? "true" : "false");
        const basePrice   = @(p.IsContactPrice || p.IsOutOfStock ? "0" : p.Price.ToString(System.Globalization.CultureInfo.InvariantCulture));
        const currentSlug = '@(RouteData.Values["slug"]?.ToString() ?? "")';

        let currentIdx    = 0;
        let selectedLabel = null;
        let selectedPrice = null;

        // ── Gallery ──
        function setImg(idx) {
            currentIdx = idx;
            document.getElementById('main-img').src = images[idx];
            document.querySelectorAll('.gallery-thumbs img').forEach((el, i) => {
                el.classList.toggle('active', i === idx);
            });
        }

        function changeImg(dir) {
            setImg((currentIdx + dir + images.length) % images.length);
        }

        function changeDetailQty(dir) {
            const inp = document.getElementById('qty-input');
            inp.value = Math.max(1, Math.min(99, parseInt(inp.value) + dir));
        }

        // ── Size selector ──
        function selectSize(btn) {
            document.querySelectorAll('.size-option-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            selectedLabel = btn.dataset.label;
            selectedPrice = parseFloat(btn.dataset.price);
            document.getElementById('size-error').style.display = 'none';
        }

        // ── Add to cart ──
        function addToCartDetail() {
            const qty = parseInt(document.getElementById('qty-input').value) || 1;

            if (hasSizes) {
                if (!selectedLabel) {
                    document.getElementById('size-error').style.display = 'block';
                    showToast('warning', 'Chưa chọn size', 'Vui lòng chọn size trước khi thêm vào giỏ.');
                    return;
                }
                const cartKey  = `${productId}_${selectedLabel}`;
                const itemName = `${productName} (${selectedLabel})`;

                if (!cart[cartKey]) {
                    cart[cartKey] = {
                        id:    cartKey,
                        name:  itemName,
                        price: selectedPrice,
                        image: productImg,
                        label: selectedLabel,
                        qty:   0
                    };
                }
                cart[cartKey].qty += qty;
            } else {
                if (!cart[productId]) {
                    cart[productId] = {
                        id:    productId,
                        name:  productName,
                        price: basePrice,
                        image: productImg,
                        label: null,
                        qty:   0
                    };
                }
                cart[productId].qty += qty;
            }

            saveCart();
            refreshCart();
            showToast('success', 'Thêm vào giỏ hàng',
                `Đã thêm <b>${hasSizes ? productName + ' (' + selectedLabel + ')' : productName}</b> vào giỏ!`);
        }

        // ── Buy now ──
        function buyNow() {
            if (hasSizes && !selectedLabel) {
                document.getElementById('size-error').style.display = 'block';
                showToast('warning', 'Chưa chọn size', 'Vui lòng chọn size trước khi mua.');
                return;
            }
            addToCartDetail();
            setTimeout(() => window.location.href = '/Checkout', 500);
        }

        // ── REVIEWS ──────────────────────────────────────────────────────────

        function renderStars(score) {
            return '★'.repeat(score) + '☆'.repeat(5 - score);
        }

        function getInitials(name) {
            if (!name) return '?';
            return name.trim().split(' ')
                .filter(w => w.length > 0)
                .map(w => w[0]).join('').substring(0, 2).toUpperCase();
        }

        function appendReviewCards(items) {
            const list  = document.getElementById('reviews-list');
            const empty = document.getElementById('empty-msg');
            if (empty) empty.remove();

            items.forEach(r => {
                const div = document.createElement('div');
                div.className = 'review-card';
                div.innerHTML = `
                    <div class="review-header">
                        <div class="review-avatar">${getInitials(r.userName)}</div>
                        <div class="review-meta">
                            <div class="reviewer-name">${r.userName ?? 'Khách hàng'}</div>
                        </div>
                        <div class="review-stars">${renderStars(r.score ?? 0)}</div>
                    </div>
                    <p class="review-comment">${(r.comment ?? '').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</p>
                `;
                list.appendChild(div);
            });
        }

        async function loadMoreReviews() {
            const btn = document.getElementById('btn-load-more');
            if (!btn) return;

            const page  = parseInt(btn.dataset.page);
            const total = parseInt(btn.dataset.total);

            btn.disabled    = true;
            btn.textContent = 'Đang tải...';

            try {
                const res  = await fetch(`?handler=Reviews&slug=${encodeURIComponent(currentSlug)}&page=${page}`);
                const data = await res.json();

                if (data.items?.length) appendReviewCards(data.items);

                const nextPage = page + 1;
                if (nextPage > total) {
                    btn.parentElement.remove();
                } else {
                    btn.dataset.page    = nextPage;
                    btn.disabled        = false;
                    btn.textContent     = 'Xem thêm đánh giá';
                }
            } catch {
                btn.disabled    = false;
                btn.textContent = 'Xem thêm đánh giá';
                showToast('warning', 'Lỗi', 'Không thể tải thêm đánh giá.');
            }
        }

        async function submitReview() {
            const comment = document.getElementById('rv-comment').value.trim();
            const scoreEl = document.querySelector('input[name="rv-score"]:checked');
            const btn     = document.getElementById('btn-submit-rv');

            if (!scoreEl) {
                showToast('warning', 'Thiếu đánh giá', 'Vui lòng chọn số sao.'); return;
            }
            if (!comment) {
                showToast('warning', 'Thiếu nhận xét', 'Vui lòng viết nhận xét.'); return;
            }

            btn.disabled    = true;
            btn.textContent = 'Đang gửi...';

            try {
                const res = await fetch('?handler=Review', {
                    method:  'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken':
                            document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
                    },
                    body: JSON.stringify({
                        productId: productId,
                        score:     parseInt(scoreEl.value),
                        comment:   comment
                    })
                });

                // Chưa đăng nhập → server trả 401
                if (res.status === 401) {
                    showToast('warning', 'Chưa đăng nhập', 'Vui lòng đăng nhập để gửi đánh giá.');
                    setTimeout(() => window.location.href = '/Login?returnUrl=' + encodeURIComponent(window.location.pathname), 1200);
                    return;
                }

                const data = await res.json();

                if (data.success) {
                    showToast('success', 'Cảm ơn bạn!', 'Đánh giá đã được ghi nhận.');
                    setTimeout(() => window.location.reload(), 1200);
                    // appendReviewCards([{
                    //     userName: data.userName,
                    //     score:    parseInt(scoreEl.value),
                    //     comment:  comment
                    // }]);
                    // document.getElementById('rv-comment').value = '';
                    // document.querySelectorAll('input[name="rv-score"]').forEach(r => r.checked = false);
                    // const countEl = document.getElementById('review-count');
                    // if (countEl) countEl.textContent = parseInt(countEl.textContent || '0') + 1;
                } else {
                    showToast('warning', 'Thất bại', data.message ?? 'Gửi đánh giá thất bại.');
                }
            } catch {
                showToast('warning', 'Lỗi kết nối', 'Không thể gửi đánh giá, thử lại.');
            } finally {
                btn.disabled    = false;
                btn.textContent = 'Gửi đánh giá';
            }
        }
    </script>
}
