@page
@model IndexModel
@{
    ViewData["Title"] = "Trang Chu - HoaCau Fishing Store";
    ViewData["ActivePage"] = "Home";
}

<!-- BANNER -->
<div class="banner">
    <div class="banner-content">
        <div class="banner-discount">GIẢM 70%</div>
        <div class="banner-sub">Cùng nhiều quà tặng hấp dẫn</div>
        <button class="banner-btn"
                onclick="document.getElementById('new-section').scrollIntoView({behavior:'smooth'})">
            MUA NGAY
        </button>
    </div>
    <div class="banner-deco">🎣</div>
    <div class="banner-card">💳 &nbsp;CREDIT CARD ACCEPTED</div>
    <div class="banner-shape"></div>
</div>

<!-- SẢN PHẨM MỚI -->
<div class="section" id="new-section">
    <div class="section-title">Sản phẩm mới</div>
    <div class="section-divider"></div>

    @if (Model.NewProducts.Any())
    {
        <div class="product-grid">
            @foreach (var p in Model.NewProducts)
            {
                <div class="product-card" onclick="location.href='/Products/@p.Slug'">
                    @if (p.DiscountPercent.HasValue)
                    {
                        <div class="product-badge">-@p.DiscountPercent%</div>
                    }

                    <div class="product-img">
                        <img src="@p.ImageUrl" alt="@p.Name"
                             onerror="this.src='/images/placeholder.jpg'"
                             style="width:100%;height:100%;object-fit:cover;" />
                    </div>

                    <div class="card-actions">
                        <button class="btn-buy"
                                onclick="event.stopPropagation();addToCart(@p.Id, @Json.Serialize(new { id = p.Id, name = p.Name, price = p.Price, imageUrl = p.ImageUrl }))">
                            Mua hàng
                        </button>
                        <button class="btn-view"
                                onclick="event.stopPropagation();location.href='/Products/@p.Slug'">
                            Xem nhanh
                        </button>
                    </div>

                    <div class="card-info">
                        <div class="card-name">@p.Name</div>
                        <div class="card-price">
                            @if (p.IsContactPrice)
                            {
                                <span class="price-new">Liên hệ</span>
                            }
                            else
                            {
                                <span class="price-new">@p.Price.ToString("N0")đ</span>
                                @if (p.OriginalPrice.HasValue)
                                {
                                    <span class="price-old">@p.OriginalPrice.Value.ToString("N0")đ</span>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p style="text-align:center;color:#aaa;padding:40px 0;">Chưa có sản phẩm mới.</p>
    }
</div>

<!-- SẢN PHẨM NỔI BẬT -->
