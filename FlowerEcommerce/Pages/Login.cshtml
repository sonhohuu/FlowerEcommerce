@page
@model FlowerEcommerce.View.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "_AuthLayout";
}

<div class="glass-card" id="auth-card">
    <h1 class="card-title">Login</h1>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="success-banner">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error-banner">@Model.ErrorMessage</div>
    }

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="error-summary"></div>

        <div class="form-group">
            <label class="field-label" asp-for="Input.UserName">Username</label>
            <input asp-for="Input.UserName" class="field-input" placeholder="Enter your username" autocomplete="username" />
            <span asp-validation-for="Input.UserName" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label class="field-label" asp-for="Input.Password">Password</label>
            <input asp-for="Input.Password" class="field-input" placeholder="Enter your password" autocomplete="current-password" />
            <span asp-validation-for="Input.Password" class="field-validation-error"></span>
        </div>

        <div class="options-row">
            <label class="checkbox-label">
                <input asp-for="Input.RememberMe" type="checkbox" />
                Remember me
            </label>
            <a href="/forgot-password" class="link-text">Forgot password?</a>
        </div>

        <button type="submit" class="submit-btn">Log In</button>
    </form>

    <p class="switch-text">
        Don't have an account? <a asp-page="/Register" class="switch-link">Register</a>
    </p>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.querySelector('form').addEventListener('submit', function () {
            const btn = this.querySelector('.submit-btn');
            btn.querySelector('.btn-text').style.display = 'none';
            btn.querySelector('.btn-spinner').style.display = 'inline';
            btn.disabled = true;
        });
    </script>
}
