                font-family:'Oswald',sans-serif;font-weight:700;font-size:15px;
                text-transform:uppercase;text-decoration:none;transition:background 0.2s;">
                🔗 Thanh toán qua PayOS
            </a>
        </div>

        <div class="success-actions">
            <a href="/OrderHistory" class="history-btn" onclick="clearCartAfterOrder()">Xem đơn hàng</a>
            <a href="/Products" class="back-btn" onclick="clearCartAfterOrder()">Tiếp tục mua sắm</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script >
        // ── Load cart ──
        function loadCheckoutCart() {
            const cart  = JSON.parse(localStorage.getItem('cart') || '{}');
            const items = Object.values(cart);
            const container = document.getElementById('checkout-items');

            if (items.length === 0) {
                container.innerHTML = '<div class="empty-checkout-cart">🛒<br><br>Giỏ hàng đang trống</div>';
                document.getElementById('subtotal-price').textContent    = '0đ';
                document.getElementById('grand-total-price').textContent = '0đ';
                return;
            }

            const total = items.reduce((s, i) => s + i.price * i.qty, 0);

            container.innerHTML = items.map(i => `
                <div class="summary-item">
                    ${i.image
                        ? `<img src="${i.image}" alt="${i.name}" />`
                        : `<div class="summary-item-emoji">🛍️</div>`}
                    <div class="summary-item-info">
                        <div class="summary-item-name">${i.name}</div>
                        <div class="summary-item-qty">x${i.qty}</div>
                    </div>
                    <div class="summary-item-price">${fmt(i.price * i.qty)}</div>
                </div>`).join('');

            document.getElementById('subtotal-price').textContent    = fmt(total);
            document.getElementById('grand-total-price').textContent = fmt(total);
        }

        // ── Payment toggle ──
        document.querySelectorAll('input[name="payment"]').forEach(radio => {
            radio.addEventListener('change', function () {
                document.getElementById('bank-detail').classList.toggle('show', this.value === '1');
            });
        });

        // ── Validation ──
        function validateField(id, errId, checkFn) {
            const el  = document.getElementById(id);
            const err = document.getElementById(errId);
            const ok  = checkFn(el.value.trim());
            el.classList.toggle('error', !ok);
            err.style.display = ok ? 'none' : 'block';
            return ok;
        }

        function validate() {
            const nameOk  = validateField('receiver-name',    'err-name',    v => v.length >= 2);
            const phoneOk = validateField('receiver-phone',   'err-phone',   v => /^[0-9]{10,11}$/.test(v.replace(/\s/g, '')));
            const addrOk  = validateField('receiver-address', 'err-address', v => v.length >= 5);
            return nameOk && phoneOk && addrOk;
        }

        // ── Build payload theo đúng schema API ──
        function buildPayload() {
            const cart  = JSON.parse(localStorage.getItem('cart') || '{}');
            const items = Object.values(cart);
            const paymentMethod = parseInt(document.querySelector('input[name="payment"]:checked').value); // 0 = COD, 1 = BankTransfer

            return {
                customerName:  document.getElementById('receiver-name').value.trim(),
                phoneNumber:   document.getElementById('receiver-phone').value.trim().replace(/\s/g, ''),
                address:       document.getElementById('receiver-address').value.trim(),
                note:          document.getElementById('receiver-note').value.trim() || null,
                paymentMethod: paymentMethod,   // int: 0 | 1
                items: items.map(i => ({
                    productId: typeof i.id === 'string' ? parseInt(i.id.split('_')[0], 10) : i.id,
                    quantity:  i.qty,
                    label:     i.label || null,
                    price:     i.price
                }))
            };
        }

        // ── Place order ──
        async function placeOrder() {
            if (!validate()) return;

            const cart = JSON.parse(localStorage.getItem('cart') || '{}');
            if (Object.keys(cart).length === 0) {
                showToast('warning', 'Giỏ hàng trống', 'Vui lòng thêm sản phẩm trước khi đặt hàng.');
                return;
            }

            const btn = document.getElementById('place-order-btn');
            document.getElementById('btn-text').style.display    = 'none';
            document.getElementById('btn-spinner').style.display = 'inline-block';
            btn.disabled = true;

            try {
                const res = await fetch('/Checkout?handler=PlaceOrder', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify(buildPayload())
                });

                if (res.status === 401) {
                    showToast('info', 'Chưa đăng nhập',
                        'Vui lòng <a href="/Login?returnUrl=/Checkout">đăng nhập</a> để đặt hàng.', 0);
                    return;
                }

                const data = await res.json();

        if (res.ok && data.success) {
            const orderCode = data.data?.orderCode ?? '';
            const checkoutUrl = data.data?.checkoutUrl ?? null;
            const qrCodeString = data.data?.qrCode ?? null;

            document.getElementById('success-order-code').textContent =
            orderCode ? '#' + orderCode : '';

            const payVal = parseInt(document.querySelector('input[name="payment"]:checked').value);

            if (payVal === 1 && checkoutUrl) {
                document.getElementById('bank-payment-detail').style.display = 'block';
                document.getElementById('checkout-url-btn').href = checkoutUrl;

            const qrContainer = document.getElementById('qr-canvas');
                qrContainer.innerHTML = '';
                if (qrCodeString) {
                    new QRCode(qrContainer, {
                        text: qrCodeString,
                        width: 180,
                        height: 180,
                        colorDark: '#111111',
                        colorLight: '#ffffff',
                        correctLevel: QRCode.CorrectLevel.M
                    });
                }

            document.getElementById('success-msg').innerHTML =
                'Quét mã QR hoặc nhấn nút bên dưới để thanh toán.<br>Đơn hàng xử lý sau khi xác nhận chuyển khoản.';

            setTimeout(() => {
                document.getElementById('success-overlay').classList.add('show');
            }, 200);
            return;

            } else {
                document.getElementById('bank-payment-detail').style.display = 'none';
                document.getElementById('success-msg').innerHTML =
                'Cảm ơn bạn đã mua hàng.<br>Chúng tôi sẽ liên hệ xác nhận đơn hàng sớm nhất.';
            }

            document.getElementById('success-overlay').classList.add('show');
            } else {
                    const errMsg = data.message
                        || (data.validationErrors
                            ? Object.values(data.validationErrors).flat().join(' · ')
                            : null)
                        || 'Đặt hàng không thành công. Vui lòng thử lại.';

                    showToast('error', 'Đặt hàng thất bại', errMsg);
                }
            } catch {
                showToast('error', 'Lỗi kết nối', 'Không thể kết nối máy chủ. Vui lòng thử lại sau.');
            } finally {
                document.getElementById('btn-text').style.display    = 'inline';
                document.getElementById('btn-spinner').style.display = 'none';
                btn.disabled = false;
            }
        }

        function clearCartAfterOrder() {
            localStorage.removeItem('cart');
            if (typeof refreshCart === 'function') refreshCart();
        }

        // ── Real-time validation on blur ──
        document.getElementById('receiver-name').addEventListener('blur', () =>
            validateField('receiver-name', 'err-name', v => v.length >= 2));
        document.getElementById('receiver-phone').addEventListener('blur', () =>
            validateField('receiver-phone', 'err-phone', v => /^[0-9]{10,11}$/.test(v.replace(/\s/g, ''))));
        document.getElementById('receiver-address').addEventListener('blur', () =>
            validateField('receiver-address', 'err-address', v => v.length >= 5));

        document.addEventListener('DOMContentLoaded', loadCheckoutCart);
    </script>
}
