<!-- SUCCESS OVERLAY -->
<div class="success-overlay" id="success-overlay">
    <div class="success-box">
        <div class="success-icon">🎉</div>
        <div class="success-order-code" id="success-order-code"></div>
        <h2>Đặt hàng thành công!</h2>
        <p id="success-msg">Cảm ơn bạn đã mua hàng.<br>Chúng tôi sẽ liên hệ xác nhận đơn hàng sớm nhất.</p>

        <!-- BANK TRANSFER: QR + link (ẩn mặc định) -->
        <div id="bank-payment-detail" style="display:none; margin-bottom:20px;">
            <div id="qr-wrapper" style="margin:0 auto 14px; width:fit-content; padding:10px; border:1.5px solid #e55a00; border-radius:8px; background:#fff;">
                <div id="qr-canvas"></div>
            </div>
            <a id="checkout-url-btn" href="#" target="_blank"
