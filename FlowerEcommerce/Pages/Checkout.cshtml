@page
@model FlowerEcommerce.View.Pages.CheckoutModel
@section Styles {
    <style>
        /* ── PAGE WRAPPER ── */
        .checkout-page {
            max-width: 1200px;
            margin: 40px auto 64px;
            padding: 0 24px;
            display: grid;
            grid-template-columns: 1fr 420px;
            gap: 40px;
            align-items: start;
        }

        /* ── SECTION HEADINGS ── */
        .section-block {
            background: #fff;
            border: 1px solid #ebebeb;
            border-radius: 8px;
            padding: 28px 32px;
            margin-bottom: 24px;
            animation: fadeUp 0.4s ease both;
        }

            .section-block:nth-child(2) {
                animation-delay: 0.08s;
            }

            .section-block:nth-child(3) {
                animation-delay: 0.16s;
            }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(18px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section-title {
            font-family: 'Oswald', sans-serif;
            font-size: 16px;
            font-weight: 700;
            text-transform: uppercase;
            color: #111;
            margin: 0 0 22px;
            padding-bottom: 12px;
            border-bottom: 2px solid #e55a00;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .section-title .step-badge {
                width: 26px;
                height: 26px;
                background: #e55a00;
                color: #fff;
                border-radius: 50%;
                font-size: 13px;
                font-weight: 700;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

        /* ── FORM ── */
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-bottom: 16px;
        }

            .form-group label {
                font-size: 13px;
                font-weight: 600;
                color: #333;
            }

                .form-group label .req {
                    color: #e55a00;
                    margin-left: 2px;
                }

            .form-group input,
            .form-group textarea {
                padding: 11px 14px;
                border: 1.5px solid #ddd;
                border-radius: 6px;
                font-size: 14px;
                color: #222;
                font-family: 'Source Sans 3', sans-serif;
                transition: border-color 0.2s, box-shadow 0.2s;
                background: #fafafa;
            }

                .form-group input:focus,
                .form-group textarea:focus {
                    outline: none;
                    border-color: #e55a00;
                    box-shadow: 0 0 0 3px rgba(229,90,0,0.10);
                    background: #fff;
                }

                .form-group input.error,
                .form-group textarea.error {
                    border-color: #e53935;
                }

            .form-group .err-msg {
                font-size: 12px;
                color: #e53935;
                display: none;
            }

            .form-group textarea {
                resize: vertical;
                min-height: 80px;
            }

        /* ── PAYMENT METHODS ── */
        .payment-options {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .payment-option {
            position: relative;
        }

            .payment-option input[type="radio"] {
                position: absolute;
                opacity: 0;
                width: 0;
            }

            .payment-option label {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 10px;
                padding: 20px 16px;
                border: 2px solid #e0e0e0;
                border-radius: 8px;
                cursor: pointer;
                transition: border-color 0.2s, background 0.2s, transform 0.15s;
                background: #fafafa;
                text-align: center;
            }

                .payment-option label:hover {
                    border-color: #e55a00;
                    background: #fff8f5;
                    transform: translateY(-2px);
                }

            .payment-option input[type="radio"]:checked + label {
                border-color: #e55a00;
                background: #fff3ed;
                box-shadow: 0 0 0 3px rgba(229,90,0,0.12);
            }

        .payment-icon {
            font-size: 32px;
            line-height: 1;
        }

        .payment-name {
            font-family: 'Oswald', sans-serif;
            font-size: 14px;
            font-weight: 600;
            color: #222;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .payment-desc {
            font-size: 12px;
            color: #888;
            line-height: 1.4;
        }

        .payment-option input[type="radio"]:checked + label .payment-name {
            color: #e55a00;
        }

        .bank-detail {
            display: none;
            margin-top: 16px;
            background: #fff8f0;
            border: 1.5px dashed #e55a00;
            border-radius: 8px;
            padding: 16px 20px;
            font-size: 13.5px;
            color: #444;
            line-height: 2;
            animation: fadeUp 0.25s ease;
        }

            .bank-detail.show {
                display: block;
            }

            .bank-detail b {
                color: #111;
            }

        /* ── API ERROR ── */
        .api-error {
            display: none;
            background: #fdecea;
            border: 1.5px solid #f5c6cb;
            border-radius: 6px;
            padding: 12px 16px;
            font-size: 13px;
            color: #721c24;
            margin-top: 12px;
        }

            .api-error.show {
                display: block;
            }

        /* ── ORDER SUMMARY ── */
        .order-summary {
            position: sticky;
            top: 20px;
            background: #fff;
            border: 1px solid #ebebeb;
            border-radius: 8px;
            overflow: hidden;
            animation: fadeUp 0.4s ease 0.1s both;
        }

        .summary-header {
            background: #111;
            color: #fff;
            padding: 16px 24px;
            font-family: 'Oswald', sans-serif;
            font-size: 15px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .summary-items {
            padding: 0 24px;
            max-height: 340px;
            overflow-y: auto;
        }

            .summary-items::-webkit-scrollbar {
                width: 4px;
            }

            .summary-items::-webkit-scrollbar-track {
                background: #f5f5f5;
            }

            .summary-items::-webkit-scrollbar-thumb {
                background: #ddd;
                border-radius: 2px;
            }

        .summary-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 0;
            border-bottom: 1px solid #f0f0f0;
        }

            .summary-item:last-child {
                border-bottom: none;
            }

            .summary-item img {
                width: 56px;
                height: 56px;
                object-fit: cover;
                border-radius: 6px;
                border: 1px solid #eee;
                flex-shrink: 0;
                background: #f5f5f5;
            }

        .summary-item-emoji {
            width: 56px;
            height: 56px;
            border-radius: 6px;
            border: 1px solid #eee;
            background: #f5f5f5;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            flex-shrink: 0;
        }

        .summary-item-info {
            flex: 1;
            min-width: 0;
        }

        .summary-item-name {
            font-size: 13px;
            font-weight: 600;
            color: #222;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .summary-item-qty {
            font-size: 12px;
            color: #888;
            margin-top: 2px;
        }

        .summary-item-price {
            font-size: 14px;
            font-weight: 700;
            color: #e55a00;
            white-space: nowrap;
        }

        .empty-checkout-cart {
            text-align: center;
            padding: 32px 0;
            color: #aaa;
            font-size: 14px;
        }

        .summary-totals {
            padding: 16px 24px;
            border-top: 1px solid #ebebeb;
            background: #fafafa;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            color: #555;
            margin-bottom: 8px;
        }

            .total-row.grand {
                font-family: 'Oswald', sans-serif;
                font-size: 18px;
                font-weight: 700;
                color: #111;
                margin-top: 12px;
                padding-top: 12px;
                border-top: 2px solid #e55a00;
            }

                .total-row.grand span:last-child {
                    color: #e55a00;
                }

        /* ── SUBMIT BUTTON ── */
        .submit-order-btn {
            width: 100%;
            padding: 16px;
            background: #e55a00;
            color: #fff;
            border: none;
            font-family: 'Oswald', sans-serif;
            font-size: 17px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .submit-order-btn:hover {
                background: #c44e00;
                transform: translateY(-1px);
            }

            .submit-order-btn:active {
                transform: translateY(0);
            }

            .submit-order-btn:disabled {
                background: #ccc;
                cursor: not-allowed;
                transform: none;
            }

            .submit-order-btn .spinner {
                display: none;
                width: 18px;
                height: 18px;
                border: 2.5px solid rgba(255,255,255,0.4);
                border-top-color: #fff;
                border-radius: 50%;
                animation: spin 0.7s linear infinite;
            }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* ── SUCCESS OVERLAY ── */
        .success-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.55);
            z-index: 9999;
            align-items: center;
            justify-content: center;
        }

            .success-overlay.show {
                display: flex;
            }

        .success-box {
            background: #fff;
            border-radius: 12px;
            padding: 48px 40px;
            text-align: center;
            max-width: 420px;
            width: 90%;
            animation: popIn 0.35s cubic-bezier(0.175,0.885,0.32,1.275);
        }

        @@keyframes popIn {
            from {
                opacity: 0;
                transform: scale(0.8);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .success-icon {
            font-size: 64px;
            margin-bottom: 16px;
            animation: bounce 0.6s ease 0.3s both;
        }

        @@keyframes bounce {
            0% {
                transform: scale(0);
            }

            60% {
                transform: scale(1.2);
            }

            100% {
                transform: scale(1);
            }
        }

        .success-order-code {
            font-family: 'DM Sans', 'Oswald', sans-serif;
            font-size: 13px;
            color: #e55a00;
            background: #fff3ed;
            padding: 5px 14px;
            border-radius: 20px;
            display: inline-block;
            margin-bottom: 14px;
            letter-spacing: .3px;
            font-variant-numeric: tabular-nums;
        }

        .success-box h2 {
            font-family: 'Oswald', sans-serif;
            font-size: 24px;
            font-weight: 700;
            color: #111;
            margin: 0 0 10px;
        }

        .success-box p {
            font-size: 14px;
            color: #666;
            margin: 0 0 28px;
            line-height: 1.6;
        }

        .success-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .success-box .back-btn {
            display: inline-block;
            padding: 12px 24px;
            background: #e55a00;
            color: #fff;
            border-radius: 6px;
            font-family: 'Oswald', sans-serif;
            font-weight: 700;
            font-size: 15px;
            text-transform: uppercase;
            text-decoration: none;
            transition: background 0.2s;
        }

            .success-box .back-btn:hover {
                background: #c44e00;
            }

        .success-box .history-btn {
            display: inline-block;
            padding: 12px 24px;
            background: #fff;
            color: #e55a00;
            border: 2px solid #e55a00;
            border-radius: 6px;
            font-family: 'Oswald', sans-serif;
            font-weight: 700;
            font-size: 15px;
            text-transform: uppercase;
            text-decoration: none;
            transition: all 0.2s;
        }

            .success-box .history-btn:hover {
                background: #fff3ed;
            }

        /* ── RESPONSIVE ── */
        @@media (max-width: 860px) {
            .checkout-page {
                grid-template-columns: 1fr;
            }

            .order-summary {
                position: static;
                order: -1;
            }

            .form-row {
                grid-template-columns: 1fr;
            }

            .payment-options {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media (max-width: 480px) {
            .payment-options {
                grid-template-columns: 1fr;
            }

            .checkout-page {
                padding: 0 16px;
                margin-top: 24px;
            }

            .section-block {
                padding: 20px 16px;
            }
        }
    </style>
}

<!-- Breadcrumb -->
<div class="breadcrumb" style="padding:12px 40px;font-size:14px;color:#555;background:#f5f5f5;border-bottom:1px solid #e0e0e0;">
    <a href="/" style="color:#555;text-decoration:none;">Trang chủ</a>
