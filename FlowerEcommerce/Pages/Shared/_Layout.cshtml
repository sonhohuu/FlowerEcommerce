<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CanCauVoDich — Trang chủ</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
 
    <!-- TOP BAR -->
    <div class="top-bar">
        <div>Hotline: <strong>1900 0000</strong> &nbsp;|&nbsp; Email: hhson@gmail.com.vn</div>
        <div>
            @if (!string.IsNullOrEmpty(Context.Session.GetString("username")))
            {
                <span style="color: #fff; font-weight: 500;">
                    👤 @Context.Session.GetString("username")
                </span>
                <a href="/Logout">Đăng xuất</a>
            }
            else
            {
                <a href="/Login">Đăng nhập</a>
                <a href="/Register">Đăng ký</a>
            }
            <a href="/Contact">Liên hệ</a>
        </div>
    </div>

    <!-- HEADER -->
    <div class="header">
        <div class="logo">
            <span class="logo-your">CanCau</span>&nbsp;<span class="logo-shop">SHOP</span>
        </div>
    </div>

    <!-- NAV -->
    <nav class="nav">
        <div class="nav-links">
            <a href="/">Trang chủ</a>
            <a href="/Introduction">Giới thiệu</a>
            <a href="/Products">Sản phẩm</a>
            <a href="/Contact">Liên hệ</a>
            <a href="/News">Tin tức</a>
        </div>
        <div class="nav-icons">
            <button onclick="toggleSearch()" title="Tìm kiếm">🔍</button>
            <button onclick="toggleCart()" title="Giỏ hàng">
                🛒<span class="cart-badge" id="cart-count">0</span>
            </button>
        </div>
    </nav>

    <!-- SEARCH BAR -->
    <div class="search-bar" id="search-bar">
        <input type="text" placeholder="Tìm kiếm sản phẩm..." id="search-input" />
        <button class="search-close" onclick="toggleSearch()">✕</button>
    </div>
 
<!-- MAIN CONTENT -->
<main>
    @RenderBody()
</main>
<!-- FOOTER -->
    <footer class="footer">
        <div class="footer-grid">
            <div class="footer-col">
                <h4>Về chúng tôi</h4>
                <a href="#">Trang chủ</a>
                <a href="#">Giới thiệu</a>
                <a href="#">Sản phẩm</a>
                <a href="#">Liên hệ</a>
                <a href="#">Tin tức</a>
            </div>
            <div class="footer-col">
                <h4>Chính sách</h4>
                <a href="#">Chính sách đổi trả</a>
                <a href="#">Chính sách vận chuyển</a>
                <a href="#">Bảo mật thông tin</a>
                <a href="#">Điều khoản sử dụng</a>
                <a href="#">Hướng dẫn mua hàng</a>
            </div>
            <div class="footer-col">
                <h4>Hỗ trợ khách hàng</h4>
                <a href="#">Trang chủ</a>
                <a href="#">Giới thiệu</a>
                <a href="#">Sản phẩm</a>
                <a href="#">Liên hệ</a>
                <a href="#">Tin tức</a>
            </div>
            <div class="footer-col">
                <h4>Đăng ký nhận khuyến mãi</h4>
                <div class="email-row">
                    <input class="email-input" type="email" placeholder="Nhập địa chỉ email" />
                    <button class="email-btn">Đăng ký</button>
                </div>
                <h4 style="margin-top: 24px;">Theo dõi chúng tôi</h4>
                <div class="social-icons">
                    <a class="social-icon" href="#">𝕏</a>
                    <a class="social-icon" href="#">f</a>
                    <a class="social-icon" href="#">𝓟</a>
                    <a class="social-icon" href="#">G</a>
                    <a class="social-icon" href="#">▶</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">© 2026 Cancau Shop</div>
    </footer>

    <!-- CART OVERLAY + PANEL -->
    <div class="cart-overlay" id="cart-overlay" onclick="toggleCart()"></div>
    <div class="cart-panel" id="cart-panel">
        <div class="cart-header">
            <h3>🛒 Giỏ hàng của bạn</h3>
            <button class="cart-close" onclick="toggleCart()">✕</button>
        </div>
        <div class="cart-items" id="cart-items-list"></div>
        <div class="cart-footer">
            <div class="cart-total">
                <span>Tổng cộng</span>
                <span id="cart-total-price">0đ</span>
            </div>
            <button class="checkout-btn" onclick="checkout()">Thanh toán ngay →</button>
        </div>
    </div>

    <!-- TOAST -->
    <div class="toast" id="toast"></div>

<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>