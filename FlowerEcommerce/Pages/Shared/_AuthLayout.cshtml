<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – YourApp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Raleway:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
            *, *::before, *::after {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                min-height: 100vh;
                font-family: 'Raleway', sans-serif;
                background: #f5f5f0;
                display: flex;
                align-items: center;
                justify-content: center;
                position: relative;
            }

            /* ── Glass card ── */
            .glass-card {
                position: relative;
                z-index: 10;
                width: 100%;
                max-width: 440px;
                margin: 24px;
                background: #ffffff;
                border: 1px solid rgba(0,0,0,.08);
                border-radius: 20px;
                padding: 48px 44px;
                box-shadow: 0 4px 24px rgba(0,0,0,.08), 0 1px 4px rgba(0,0,0,.04);
                animation: fadeSlideUp .5s cubic-bezier(.16,1,.3,1) both;
            }

            @@keyframes fadeSlideUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .card-title {
                font-family: 'Cinzel', serif;
                font-size: 1.8rem;
                font-weight: 700;
                color: #1a1a2e;
                text-align: center;
                margin-bottom: 32px;
                letter-spacing: .04em;
            }

            /* ── Form elements ── */
            .form-group {
                margin-bottom: 20px;
                position: relative;
            }

            .form-row {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 14px;
                margin-bottom: 20px;
            }

                .form-row .form-group {
                    margin-bottom: 0;
                }

            .field-label {
                display: block;
                font-size: .72rem;
                letter-spacing: .09em;
                color: #888;
                text-transform: uppercase;
                margin-bottom: 4px;
            }

            .field-input {
                width: 100%;
                background: transparent;
                border: none;
                border-bottom: 1px solid #d0d0d0;
                padding: 10px 0;
                color: #1a1a2e;
                font-family: 'Raleway', sans-serif;
                font-size: .9rem;
                font-weight: 400;
                outline: none;
                transition: border-color .25s;
            }

                .field-input::placeholder {
                    color: #bbb;
                }

                .field-input:focus {
                    border-bottom-color: #1a1a2e;
                }

            .focus-line {
                position: absolute;
                bottom: 0;
                left: 0;
                width: 0;
                height: 1.5px;
                background: #1a1a2e;
                transition: width .25s ease;
            }

            .field-input:focus ~ .focus-line {
                width: 100%;
            }

            .options-row {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin: 4px 0 26px;
            }

            .checkbox-label {
                display: flex;
                align-items: center;
                gap: 8px;
                cursor: pointer;
                color: #666;
                font-size: .82rem;
                user-select: none;
            }

                .checkbox-label input[type="checkbox"] {
                    width: 15px;
                    height: 15px;
                    accent-color: #1a1a2e;
                    cursor: pointer;
                }

            .link-text {
                color: #888;
                font-size: .82rem;
                text-decoration: none;
                transition: color .2s;
            }

                .link-text:hover {
                    color: #1a1a2e;
                }

            .submit-btn {
                width: 100%;
                padding: 14px;
                background: #1a1a2e;
                color: #fff;
                border: none;
                border-radius: 8px;
                font-family: 'Cinzel', serif;
                font-size: .88rem;
                font-weight: 600;
                letter-spacing: .1em;
                cursor: pointer;
                transition: all .2s ease;
                margin-bottom: 22px;
            }

                .submit-btn:hover {
                    background: #2d2d4e;
                    transform: translateY(-1px);
                    box-shadow: 0 4px 16px rgba(26,26,46,.2);
                }

                .submit-btn:active {
                    transform: translateY(0);
                }

                .submit-btn:disabled {
                    opacity: .6;
                    cursor: not-allowed;
                    transform: none;
                }

            .switch-text {
                text-align: center;
                color: #999;
                font-size: .82rem;
            }

            .switch-link {
                color: #1a1a2e;
                font-weight: 600;
                text-decoration: none;
                border-bottom: 1px solid rgba(26,26,46,.25);
                transition: border-color .2s;
            }

                .switch-link:hover {
                    border-bottom-color: #1a1a2e;
                }

            .error-msg,
            .field-validation-error {
                color: #e05050;
                font-size: .75rem;
                margin-top: 4px;
                display: block;
            }

            .error-summary {
                color: #e05050;
                font-size: .82rem;
                margin-bottom: 14px;
            }

            .success-banner {
                background: #f0faf4;
                border: 1px solid #b2dfc2;
                border-radius: 8px;
                padding: 12px 16px;
                color: #2e7d4f;
                font-size: .82rem;
                text-align: center;
                margin-bottom: 16px;
            }

            .error-banner {
                background: #fff5f5;
                border: 1px solid #f5c0c0;
                border-radius: 8px;
                padding: 12px 16px;
                color: #c0392b;
                font-size: .82rem;
                text-align: center;
                margin-bottom: 16px;
            }

            @@media (max-width: 480px) {
                .glass-card {
                    padding: 36px 24px;
                }

                .form-row {
                    grid-template-columns: 1fr;
                    gap: 0;
                }

                    .form-row .form-group {
                        margin-bottom: 20px;
                    }
            }
    </style>
</head>
<body>
    @RenderBody()

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
